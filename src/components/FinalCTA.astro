---
const feats = [
  { icon: '⚡', title: 'Direct toegang', desc: 'Binnen 2 minuten in de Skool community' },
  { icon: '✓', title: 'Maandelijks opzegbaar', desc: 'Geen lange contracten of verrassingen' },
  { icon: '👥', title: 'Nederlandse community', desc: '100% focus op Nederlandse e-commerce realiteit' }
];
---
<section class="final-cta">
  <div class="container">
    <div class="cta-card">
      <div>
        <h2>Klaar om je webshop naar <em>het volgende niveau</em> te tillen?</h2>
        <p>14 dagen gratis proberen. Geen creditcard nodig. Ontmoet vandaag nog de community die je al jaren mist.</p>
        <div class="cta-actions">
          <a href="#" class="btn btn-primary">Start 14 dagen gratis →</a>
          <a href="#" class="btn-outline">Plan een gesprek</a>
        </div>
      </div>
      <div class="cta-features">
        {feats.map(f => (
          <div class="cta-feat">
            <div class="cta-feat-icon">{f.icon}</div>
            <div>
              <div class="cta-feat-title">{f.title}</div>
              <div class="cta-feat-desc">{f.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta { padding: 120px 0; }
  .cta-card { background: var(--navy); color: #fff; border-radius: 28px; padding: 72px 60px; display: grid; grid-template-columns: 1.2fr 1fr; gap: 48px; align-items: center; position: relative; overflow: hidden; }
  .cta-card::before { content: ''; position: absolute; top: -100px; right: -100px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, color-mix(in oklab, var(--orange) 30%, transparent), transparent 70%); }
  .cta-card h2 { font-size: clamp(36px, 4.2vw, 52px); color: #fff; position: relative; }
  .cta-card h2 :global(em) { font-style: italic; color: var(--orange); }
  .cta-card p { color: rgba(255,255,255,0.75); margin-top: 16px; font-size: 17px; position: relative; }
  .cta-actions { display: flex; gap: 12px; margin-top: 32px; flex-wrap: wrap; position: relative; }
  .btn-outline { padding: 12px 20px; border-radius: 999px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2); color: #fff; font-size: 14px; font-weight: 500; }
  .cta-features { display: flex; flex-direction: column; gap: 14px; position: relative; }
  .cta-feat { display: flex; gap: 14px; align-items: flex-start; padding: 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; }
  .cta-feat-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--orange); color: var(--navy); display: grid; place-items: center; flex-shrink: 0; font-size: 18px; }
  .cta-feat-title { font-weight: 600; font-size: 15px; }
  .cta-feat-desc { font-size: 13px; color: rgba(255,255,255,0.65); margin-top: 2px; }
  @media (max-width: 960px) { .cta-card { grid-template-columns: 1fr; padding: 48px 32px; } }
</style>
