---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, excerpt, description, author, authorInitial, authorRole, category, pubDate, readingTime, cover, coverAlt } = post.data;

const allPosts = (await getCollection('blog'))
  .filter(p => p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const related = allPosts.filter(p => p.data.category === category).slice(0, 3);
const relatedToShow = related.length >= 3 ? related : allPosts.slice(0, 3);

const date = new Date(pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
const initial = authorInitial || author.charAt(0);
---

<BaseLayout title={title} description={description || excerpt} ogImage={cover}>
  <article class="article">
    <div class="container-narrow">
      <div class="breadcrumb">
        <a href="/blog">Blog</a>
        <span class="sep">/</span>
        <a href={`/blog/category/${category.toLowerCase()}`}>{category}</a>
      </div>
    </div>
    <header class="article-header">
      <span class="article-cat">{category}</span>
      <h1>{title}</h1>
      {excerpt && <p class="article-lead">{excerpt}</p>}
      <div class="article-meta-bar">
        <div class="article-author">
          <div class="author-avatar">{initial}</div>
          <div>
            <span class="article-author-name">{author}</span>
            {authorRole && <span class="article-author-role">{authorRole}</span>}
          </div>
        </div>
        <span class="meta-dot"></span>
        <span>{date}</span>
        {readingTime && <><span class="meta-dot"></span><span>{readingTime}</span></>}
      </div>
    </header>

    {cover && (
      <div class="container">
        <div class="article-hero" style={`background-image: url('${cover}'); background-size: cover; background-position: center;`} role="img" aria-label={coverAlt || title}></div>
      </div>
    )}

    <div class="container-narrow article-body">
      <Content />
    </div>
  </article>

  <section class="related">
    <div class="container">
      <div class="related-head"><h3>Ook interessant</h3></div>
      <div class="posts-grid">
        {relatedToShow.map(p => <PostCard post={p} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .article { padding: 48px 0 96px; }
  .breadcrumb { font-size: 13px; color: var(--fg-muted); margin-bottom: 24px; display: flex; gap: 8px; align-items: center; }
  .breadcrumb a:hover { color: var(--fg); }
  .sep { color: var(--fg-subtle); }
  .article-header { max-width: 760px; margin: 0 auto 40px; padding: 0 32px; }
  .article-cat { display: inline-block; background: var(--orange-50); color: var(--orange-600); padding: 4px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; }
  .article-header h1 { font-size: clamp(36px, 5vw, 60px); margin-top: 20px; }
  .article-lead { font-size: 20px; color: var(--fg-muted); margin-top: 20px; line-height: 1.55; }
  .article-meta-bar { display: flex; align-items: center; gap: 14px; margin-top: 32px; padding: 20px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); font-size: 14px; color: var(--fg-muted); flex-wrap: wrap; }
  .author-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--navy), var(--navy-500)); color: #fff; display: grid; place-items: center; font-size: 14px; font-weight: 600; }
  .article-author { display: flex; align-items: center; gap: 12px; }
  .article-author-name { color: var(--fg); font-weight: 500; display: block; }
  .article-author-role { font-size: 12px; color: var(--fg-subtle); }
  .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--fg-subtle); }
  .article-hero { aspect-ratio: 21/9; border-radius: 20px; background-image: repeating-linear-gradient(135deg, color-mix(in oklab, var(--navy) 8%, var(--bg-3)) 0 14px, var(--bg-3) 14px 28px); max-width: 1000px; margin: 0 auto 48px; border: 1px solid var(--border); }

  .article-body { font-size: 17px; line-height: 1.7; color: var(--fg); }
  .article-body :global(h2) { font-family: 'Instrument Serif'; font-size: 34px; margin-top: 48px; margin-bottom: 16px; }
  .article-body :global(h3) { font-family: 'Instrument Serif'; font-size: 24px; margin-top: 36px; margin-bottom: 12px; }
  .article-body :global(p) { margin-bottom: 20px; }
  .article-body :global(a) { color: var(--orange-600); text-decoration: underline; text-underline-offset: 3px; }
  .article-body :global(ul), .article-body :global(ol) { margin: 20px 0; padding-left: 24px; }
  .article-body :global(li) { margin-bottom: 8px; }
  .article-body :global(blockquote) { border-left: 3px solid var(--orange); padding: 12px 0 12px 24px; margin: 28px 0; font-family: 'Instrument Serif'; font-size: 24px; font-style: italic; line-height: 1.4; }
  .article-body :global(code) { background: var(--bg-3); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; }
  .article-body :global(img) { max-width: 100%; height: auto; border-radius: 12px; margin: 28px 0; }

  .related { padding: 64px 0; background: var(--bg-2); border-top: 1px solid var(--border); }
  .related-head { margin-bottom: 32px; }
  .related-head h3 { font-size: 28px; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
